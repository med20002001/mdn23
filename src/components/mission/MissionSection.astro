---
// MissionSection.astro
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

type Props = {
  text: string;
  image: ImageMetadata;
  alt: string;
  index: number;
};

const { text, image, alt, index } = Astro.props;

// Palette de couleurs subtile pour les numéros
const accentColors = [
  'from-red-500 to-orange-400',
  'from-emerald-500 to-teal-400', 
  'from-blue-500 to-indigo-400',
  'from-violet-500 to-purple-400',
  'from-pink-500 to-rose-400',
  'from-amber-500 to-yellow-400'
];
const accentColor = accentColors[index % accentColors.length];
---

<article
  class="group relative bg-white rounded-3xl overflow-hidden transition-all duration-500 ease-out
         hover:shadow-[0_20px_60px_rgba(0,0,0,0.12)] hover:-translate-y-3
         h-full flex flex-col border border-gray-100"
>
  
  <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none">
    <div class="absolute inset-0 bg-gradient-to-tr from-transparent via-white/40 to-transparent translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-1000 ease-in-out"></div>
  </div>

  
  <div class="relative h-80 overflow-hidden">
    <Image
      src={image}
      alt={alt}
      class="w-full h-full object-cover transition-all duration-700 ease-out group-hover:scale-110"
      loading="lazy"
    />
    
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent opacity-60 group-hover:opacity-80 transition-opacity duration-500"></div>
    <div class="absolute top-6 left-6 flex items-center gap-3">
      <span class={`text-5xl font-bold bg-gradient-to-r ${accentColor} bg-clip-text text-transparent drop-shadow-sm`}>
        0{index + 1}
      </span>
      <div class={`h-12 w-1 rounded-full bg-gradient-to-b ${accentColor} opacity-50`}></div>
    </div>

    <!-- Indicateur de survol -->
    <div class="absolute bottom-6 right-6 w-12 h-12 rounded-full bg-white/20 backdrop-blur-md flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-500 translate-y-4 group-hover:translate-y-0">
      <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
      </svg>
    </div>
  </div>

  <!-- Contenu avec effet de soulignement animé -->
  <div class="relative p-8 lg:p-10 flex-1 flex flex-col justify-between bg-white">
    <!-- Ligne décorative supérieure -->
    <div class={`absolute top-0 left-8 right-8 h-1 bg-gradient-to-r ${accentColor} rounded-full transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left`}></div>
    
    <p class="text-lg leading-relaxed text-gray-700 group-hover:text-gray-900 transition-colors duration-300 relative z-10">
      {text}
    </p>
  </div>

  <!-- Bordure animée -->
  <div class="absolute inset-0 rounded-3xl border-2 border-transparent group-hover:border-gray-100 transition-colors duration-300 pointer-events-none"></div>
</article>

<style>
  /* Animation d'entrée cascade */
  @keyframes slideUpFade {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  article {
    animation: slideUpFade 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--index, 0) * 150ms);
  }
</style>